{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "paths": {
      "@wolffo/three-fire": ["../src/index.ts"],
      "@wolffo/three-fire/react": ["../src/react.ts"],
      "@wolffo/three-fire/vanilla": ["../src/vanilla.ts"],
      "@wolffo/three-fire/tsl": ["../src/tsl/index.ts"],
      "@wolffo/three-fire/tsl/react": ["../src/tsl/react.ts"],
      "@wolffo/three-fire/tsl/vanilla": ["../src/tsl/vanilla.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
