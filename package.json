{
    "name": "@wolffo/three-fire",
    "version": "1.4.0",
    "type": "module",
    "sideEffects": false,
    "description": "Modern TypeScript volumetric fire effect for Three.js and React Three Fiber with WebGPU support.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/typeWolffo/THREE.Fire.git"
    },
    "bugs": {
        "url": "https://github.com/typeWolffo/THREE.Fire/issues"
    },
    "homepage": "https://github.com/typeWolffo/THREE.Fire#readme",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "module": "dist/index.esm.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.esm.js",
            "require": "./dist/index.js"
        },
        "./vanilla": {
            "types": "./dist/vanilla.d.ts",
            "import": "./dist/vanilla.esm.js",
            "require": "./dist/vanilla.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.esm.js",
            "require": "./dist/react.js"
        },
        "./tsl": {
            "types": "./dist/tsl/index.d.ts",
            "import": "./dist/tsl/index.esm.js",
            "require": "./dist/tsl/index.js"
        },
        "./tsl/vanilla": {
            "types": "./dist/tsl/vanilla.d.ts",
            "import": "./dist/tsl/vanilla.esm.js",
            "require": "./dist/tsl/vanilla.js"
        },
        "./tsl/react": {
            "types": "./dist/tsl/react.d.ts",
            "import": "./dist/tsl/react.esm.js",
            "require": "./dist/tsl/react.js"
        }
    },
    "scripts": {
        "clean": "rm -rf dist coverage",
        "build": "tsc -p tsconfig.build.json && rollup -c",
        "prebuild": "npm run clean",
        "postbuild": "rm -rf dist/types",
        "dev": "rollup -c -w",
        "dev:examples": "npm --prefix examples run dev",
        "examples:install": "npm --prefix examples install",
        "typecheck": "tsc --noEmit",
        "lint": "biome check",
        "lint:fix": "biome check --write",
        "format": "biome format --write",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build",
        "changeset": "changeset",
        "version:packages": "changeset version",
        "release": "changeset publish"
    },
    "keywords": [
        "three.js",
        "threejs",
        "react-three-fiber",
        "r3f",
        "fire",
        "volumetric",
        "shader",
        "typescript",
        "vanilla"
    ],
    "author": "wolffo",
    "license": "MIT",
    "engines": {
        "node": ">=18"
    },
    "peerDependencies": {
        "@react-three/fiber": ">=8.0.0",
        "react": ">=18.0.0",
        "three": ">=0.168.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "@react-three/fiber": {
            "optional": true
        }
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@changesets/cli": "^2.31.0",
        "@react-three/fiber": "^9.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/three": "^0.185.1",
        "@vitest/coverage-istanbul": "^4.1.7",
        "@vitest/ui": "^4.1.7",
        "happy-dom": "^20.9.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "rollup": "^4.9.2",
        "rollup-plugin-dts": "^6.1.0",
        "three": "^0.185.1",
        "tslib": "^2.6.2",
        "typescript": "^7.0.2",
        "vitest": "^4.1.7"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    }
}
